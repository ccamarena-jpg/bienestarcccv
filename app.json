{
  "expo": {
    "name": "Bitácora",
    "slug": "bitacora",
    "scheme": "bitacora",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5f1ea"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.claudia.bitacora"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f5f1ea"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.claudia.bitacora"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Bitácora necesita acceso a tus fotos para guardar tu outfit del día."
        }
      ]
    ]
  }
}
